    <update id="updateOdsSqlStatusById" parameterType="String">
        update ods_sql_pack
        <trim prefix="SET" suffixOverrides=",">
            status = "DROP"
        </trim>
        where Id = #{Id}
    </update>

    <update id="updateOdsSqlStatusByIds" parameterType="String">
        update ods_sql_pack
        <trim prefix="SET" suffixOverrides=",">
            status = "DROP"
        </trim>
        where Id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>



