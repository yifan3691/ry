        <result property="sqlGroupCode"    column="sqlGroupCode"    />
        <result property="status"    column="status"    />
    </resultMap>

    <sql id="selectOdsSqlPackVo">
        select Id, name, sqlVarchar, sqlPriority, sqlGroup, groupPriority, procedureGroup, groupOutValue, groupInValue, procedureOutValue, procedureInValue, actualid, createdate, createuserid, owneruserid, partitionid, schemaname, setid, structureid, tenantid, updatedate, updateuserid, sqlGroupCode, status from ods_sql_pack
    </sql>

    <select id="selectOdsSqlPackList" parameterType="OdsSqlPack" resultMap="OdsSqlPackResult">
        <include refid="selectOdsSqlPackVo"/>
        <where>
            status = 'EFFECTIVE'
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="sqlVarchar != null  and sqlVarchar != ''"> and lower(sqlVarchar) like concat('%', #{sqlVarchar}, '%')</if>
            <if test="sqlPriority != null "> and sqlPriority = #{sqlPriority}</if>
            <if test="sqlGroup != null  and sqlGroup != ''"> and sqlGroup = #{sqlGroup}</if>
            <if test="groupPriority != null  and groupPriority != ''"> and groupPriority = #{groupPriority}</if>
            <if test="procedureGroup != null  and procedureGroup != ''"> and procedureGroup = #{procedureGroup}</if>
        </where>
        order by groupPriority,sqlPriority asc
    </select>



    <select id="selectOdsSqlMaxId" parameterType="String">
        select max(id) from ods_sql_pack
    </select>

    <select id="selectSqlGropList" parameterType="java.util.List">
        select distinct sqlGroup from ods_sql_pack where status = 'EFFECTIVE'
    </select>

    <select id="selectSqlGropCodeList" parameterType="java.util.List">
        select distinct sqlGroupCode from ods_sql_pack where status = 'EFFECTIVE'
    </select>

    <select id="selectprocedureGroupList" parameterType="java.util.List">
        select distinct procedureGroup from ods_sql_pack where status = 'EFFECTIVE'
    </select>

    <select id="selectOdsSqlPackById" parameterType="Long" resultMap="OdsSqlPackResult">
        <include refid="selectOdsSqlPackVo"/>
        where Id = #{Id}
    </select>

    <insert id="insertOdsSqlPack" parameterType="OdsSqlPack">
        insert into ods_sql_pack
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="Id != null">Id,</if>
            <if test="name != null">name,</if>
            <if test="sqlVarchar != null">sqlVarchar,</if>
            <if test="sqlPriority != null">sqlPriority,</if>
            <if test="sqlGroup != null">sqlGroup,</if>
            <if test="groupPriority != null">groupPriority,</if>
            <if test="procedureGroup != null">procedureGroup,</if>
            <if test="groupOutValue != null">groupOutValue,</if>
            <if test="groupInValue != null">groupInValue,</if>
            <if test="procedureOutValue != null">procedureOutValue,</if>
            <if test="procedureInValue != null">procedureInValue,</if>
            <if test="actualid != null">actualid,</if>
            <if test="createdate != null">createdate,</if>
            <if test="createuserid != null">createuserid,</if>
            <if test="owneruserid != null">owneruserid,</if>
            <if test="partitionid != null">partitionid,</if>
            <if test="schemaname != null">schemaname,</if>
            <if test="setid != null">setid,</if>
            <if test="structureid != null">structureid,</if>
            <if test="tenantid != null">tenantid,</if>
            <if test="updatedate != null">updatedate,</if>
            <if test="updateuserid != null">updateuserid,</if>
            <if test="sqlGroupCode != null">sqlGroupCode,</if>
            <if test="status != null">status,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="Id != null">#{Id},</if>
            <if test="name != null">#{name},</if>
            <if test="sqlVarchar != null">#{sqlVarchar},</if>
            <if test="sqlPriority != null">#{sqlPriority},</if>
            <if test="sqlGroup != null">#{sqlGroup},</if>
            <if test="groupPriority != null">#{groupPriority},</if>
            <if test="procedureGroup != null">#{procedureGroup},</if>
            <if test="groupOutValue != null">#{groupOutValue},</if>
            <if test="groupInValue != null">#{groupInValue},</if>
            <if test="procedureOutValue != null">#{procedureOutValue},</if>
            <if test="procedureInValue != null">#{procedureInValue},</if>
            <if test="actualid != null">#{actualid},</if>
            <if test="createdate != null">#{createdate},</if>
            <if test="createuserid != null">#{createuserid},</if>
            <if test="owneruserid != null">#{owneruserid},</if>
            <if test="partitionid != null">#{partitionid},</if>
            <if test="schemaname != null">#{schemaname},</if>
            <if test="setid != null">#{setid},</if>
            <if test="structureid != null">#{structureid},</if>
            <if test="tenantid != null">#{tenantid},</if>
            <if test="updatedate != null">#{updatedate},</if>
            <if test="updateuserid != null">#{updateuserid},</if>
            <if test="sqlGroupCode != null">#{sqlGroupCode},</if>
            <if test="status != null">#{status},</if>
         </trim>
    </insert>

    <update id="updateOdsSqlPack" parameterType="OdsSqlPack">
        update ods_sql_pack
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="sqlVarchar != null">sqlVarchar = #{sqlVarchar},</if>
            <if test="sqlPriority != null">sqlPriority = #{sqlPriority},</if>
            <if test="sqlGroup != null">sqlGroup = #{sqlGroup},</if>
            <if test="groupPriority != null">groupPriority = #{groupPriority},</if>
            <if test="procedureGroup != null">procedureGroup = #{procedureGroup},</if>
            <if test="groupOutValue != null">groupOutValue = #{groupOutValue},</if>
            <if test="groupInValue != null">groupInValue = #{groupInValue},</if>
            <if test="procedureOutValue != null">procedureOutValue = #{procedureOutValue},</if>
            <if test="procedureInValue != null">procedureInValue = #{procedureInValue},</if>
            <if test="actualid != null">actualid = #{actualid},</if>
            <if test="createdate != null">createdate = #{createdate},</if>
            <if test="createuserid != null">createuserid = #{createuserid},</if>
            <if test="owneruserid != null">owneruserid = #{owneruserid},</if>
            <if test="partitionid != null">partitionid = #{partitionid},</if>
            <if test="schemaname != null">schemaname = #{schemaname},</if>
            <if test="setid != null">setid = #{setid},</if>
            <if test="structureid != null">structureid = #{structureid},</if>
            <if test="tenantid != null">tenantid = #{tenantid},</if>
