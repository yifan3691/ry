<mapper namespace="com.kevin.ods.mapper.OdsSqlPackMapper">

    <resultMap type="OdsSqlPack" id="OdsSqlPackResult">
        <result property="Id"    column="Id"    />
        <result property="name"    column="name"    />
        <result property="sqlVarchar"    column="sqlVarchar"    />
        <result property="sqlPriority"    column="sqlPriority"    />
        <result property="sqlGroup"    column="sqlGroup"    />
        <result property="groupPriority"    column="groupPriority"    />
        <result property="procedureGroup"    column="procedureGroup"    />
        <result property="groupOutValue"    column="groupOutValue"    />
        <result property="groupInValue"    column="groupInValue"    />
        <result property="procedureOutValue"    column="procedureOutValue"    />
        <result property="procedureInValue"    column="procedureInValue"    />
        <result property="actualid"    column="actualid"    />
        <result property="createdate"    column="createdate"    />
        <result property="createuserid"    column="createuserid"    />
        <result property="owneruserid"    column="owneruserid"    />
        <result property="partitionid"    column="partitionid"    />
        <result property="schemaname"    column="schemaname"    />
