<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kevin.ods.mapper.ExcelTableMapper">

    <resultMap type="ExcelTable" id="ExcelTableResult">
        <result property="tableId"    column="table_id"    />
        <result property="tableName"    column="table_name"    />
        <result property="tableComment"    column="table_comment"    />
        <result property="structureHash"    column="structure_hash"    />
        <result property="fileName"    column="file_name"    />
        <result property="rowCount"    column="row_count"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectExcelTableVo">
        select table_id, table_name, table_comment, structure_hash, file_name, row_count, status, create_by, create_time, update_by, update_time, remark from excel_table
    </sql>

    <select id="selectExcelTableList" parameterType="ExcelTable" resultMap="ExcelTableResult">
        <include refid="selectExcelTableVo"/>
        <where>
            <if test="tableName != null  and tableName != ''"> and table_name like concat('%', #{tableName}, '%')</if>
            <if test="tableComment != null  and tableComment != ''"> and table_comment like concat('%', #{tableComment}, '%')</if>
            <if test="fileName != null  and fileName != ''"> and file_name like concat('%', #{fileName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectExcelTableById" parameterType="Long" resultMap="ExcelTableResult">
        <include refid="selectExcelTableVo"/>
        where table_id = #{tableId}
    </select>

    <select id="selectExcelTableByHash" parameterType="String" resultMap="ExcelTableResult">
        <include refid="selectExcelTableVo"/>
        where structure_hash = #{structureHash}
    </select>

    <insert id="insertExcelTable" parameterType="ExcelTable" useGeneratedKeys="true" keyProperty="tableId">
        insert into excel_table
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tableName != null">table_name,</if>
            <if test="tableComment != null">table_comment,</if>
            <if test="structureHash != null">structure_hash,</if>
            <if test="fileName != null">file_name,</if>
            <if test="rowCount != null">row_count,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tableName != null">#{tableName},</if>
            <if test="tableComment != null">#{tableComment},</if>
            <if test="structureHash != null">#{structureHash},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="rowCount != null">#{rowCount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateExcelTable" parameterType="ExcelTable">
        update excel_table
        <trim prefix="SET" suffixOverrides=",">
            <if test="tableName != null">table_name = #{tableName},</if>
            <if test="tableComment != null">table_comment = #{tableComment},</if>
            <if test="structureHash != null">structure_hash = #{structureHash},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="rowCount != null">row_count = #{rowCount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where table_id = #{tableId}
    </update>

    <delete id="deleteExcelTableById" parameterType="Long">
        delete from excel_table where table_id = #{tableId}
    </delete>

    <delete id="deleteExcelTableByIds" parameterType="String">
        delete from excel_table where table_id in 
        <foreach collection="array" item="tableId" open="(" separator="," close=")">
            #{tableId}
        </foreach>
    </delete>

    <update id="createTable">
        ${sql}
    </update>

    <insert id="insertData">
        ${sql}
    </insert>

    <select id="selectTableData" resultType="java.util.HashMap">
        SELECT * FROM ${tableName}
        LIMIT #{startRow}, #{pageSize}
    </select>

    <select id="selectTableDataCount" resultType="Long">
        SELECT COUNT(*) FROM ${tableName}
    </select>

</mapper>
