<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BusinessCustomerMapper">

	<resultMap type="BusinessCustomer" id="BusinessCustomerResult">
		<id     property="customerId"    column="customer_id"     />
		<result property="customerName"  column="customer_name"   />
		<result property="phone"        column="phone"          />
		<result property="email"        column="email"          />
		<result property="address"      column="address"        />
		<result property="idCard"       column="id_card"        />
		<result property="status"       column="status"         />
		<result property="delFlag"      column="del_flag"       />
		<result property="createBy"     column="create_by"      />
		<result property="createTime"    column="create_time"    />
		<result property="updateBy"      column="update_by"      />
		<result property="updateTime"    column="update_time"    />
		<result property="remark"       column="remark"         />
	</resultMap>
	
	<sql id="selectCustomerVo">
        select customer_id, customer_name, phone, email, address, id_card, status, del_flag, create_by, create_time, update_by, update_time, remark 
		from business_customer
    </sql>
	
	<select id="selectCustomerList" parameterType="BusinessCustomer" resultMap="BusinessCustomerResult">
	    <include refid="selectCustomerVo"/>
		<where>
			<if test="customerName != null and customerName != ''">
				AND customer_name like concat('%', #{customerName}, '%')
			</if>
			<if test="phone != null and phone != ''">
				AND phone like concat('%', #{phone}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
			and del_flag = '0'
		</where>
		order by customer_id desc
	</select>
	
	<select id="selectCustomerById" parameterType="Long" resultMap="BusinessCustomerResult">
		<include refid="selectCustomerVo"/>
		where customer_id = #{customerId}
		and del_flag = '0'
	</select>

	<select id="selectCustomerByName" parameterType="String" resultMap="BusinessCustomerResult">
		<include refid="selectCustomerVo"/>
		where customer_name = #{customerName}
		and del_flag = '0'
		limit 1
	</select>
	
	<insert id="insertCustomer" parameterType="BusinessCustomer" useGeneratedKeys="true" keyProperty="customerId">
  		insert into business_customer(
  			<if test="customerName != null and customerName != ''">customer_name,</if>
  			<if test="phone != null and phone != ''">phone,</if>
  			<if test="email != null and email != ''">email,</if>
  			<if test="address != null and address != ''">address,</if>
  			<if test="idCard != null and idCard != ''">id_card,</if>
  			<if test="status != null and status != ''">status,</if>
  			<if test="remark != null and remark != ''">remark,</if>
  			<if test="createBy != null and createBy != ''">create_by,</if>
  			create_time
  		)values(
  			<if test="customerName != null and customerName != ''">#{customerName},</if>
  			<if test="phone != null and phone != ''">#{phone},</if>
  			<if test="email != null and email != ''">#{email},</if>
  			<if test="address != null and address != ''">#{address},</if>
  			<if test="idCard != null and idCard != ''">#{idCard},</if>
  			<if test="status != null and status != ''">#{status},</if>
  			<if test="remark != null and remark != ''">#{remark},</if>
  			<if test="createBy != null and createBy != ''">#{createBy},</if>
  			sysdate()
  		)
	</insert>
	
	<update id="updateCustomer" parameterType="BusinessCustomer">
	  		update business_customer
	  		<set>
	  			<if test="customerName != null and customerName != ''">customer_name = #{customerName},</if>
	  			<if test="phone != null">phone = #{phone},</if>
	  			<if test="email != null">email = #{email},</if>
	  			<if test="address != null">address = #{address},</if>
	  			<if test="idCard != null">id_card = #{idCard},</if>
	  			<if test="status != null">status = #{status},</if>
	  			<if test="remark != null">remark = #{remark},</if>
	  			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
	  			update_time = sysdate()
	  		</set>
	  		where customer_id = #{customerId}
	  		and del_flag = '0'
	</update>
	
	<delete id="deleteCustomerById">
		update business_customer
		set del_flag = '2', update_by = #{updateBy}, update_time = sysdate()
		where customer_id = #{customerId}
		and del_flag = '0'
	</delete>
	
	<delete id="deleteCustomerByIds">
  		update business_customer
		set del_flag = '2', update_by = #{updateBy}, update_time = sysdate()
		where customer_id in
  		<foreach collection="customerIds" item="customerId" open="(" separator="," close=")">
  			#{customerId}
        </foreach> 
		and del_flag = '0'
	</delete>

</mapper> 
